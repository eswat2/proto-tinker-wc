{
  "name": "proto-tinker-wc",
  "version": "0.1.231",
  "description": "prototype - simple demo built from Stencil & Tailwind",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "es2015": "dist/esm/index.mjs",
  "es2017": "dist/esm/index.mjs",
  "types": "dist/types/components.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/proto-tinker-wc/proto-tinker-wc.js",
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "bump": "bumpp patch --commit --tag --push --yes",
    "release": "pnpm bump && pnpm build",
    "preinstall": "npx only-allow pnpm",
    "dev": "concurrently \"pnpm:twx --watch\" \"pnpm:start\"",
    "twx": "twx",
    "build": "pnpm twx; pnpm format; stencil build --docs",
    "start": "stencil build --dev --watch --serve",
    "test": "echo --skip",
    "generate": "stencil generate",
    "spell": "cspell 'src/**/*.{ts,tsx,html,css,md}' ",
    "cc": "prettier --check src",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@stencil/core": "4.43.5",
    "@stencil/store": "2.2.2"
  },
  "devDependencies": {
    "autoprefixer": "10.5.4",
    "bumpp": "11.1.0",
    "concurrently": "10.0.3",
    "cspell": "10.0.1",
    "eslint": "10.7.0",
    "only-allow": "1.2.2",
    "postcss": "8.5.19",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.8.1",
    "proto-tailwindcss-clrs": "0.0.518",
    "tailwindcss": "4.3.3",
    "typescript": "5.9.3",
    "workbox-build": "7.4.1",
    "yoctocolors": "2.1.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/eswat2/proto-tinker-wc.git"
  },
  "license": "MIT",
  "packageManager": "pnpm@11.14.0+sha512.66c1ac4c7d4762d6d7dde44c7f3e5a73591ed0a0806e751d4ed32d4f004f25b2285a906b1fd8a9e3e621df3b4e2858bf88e50e0cf626bedbe977fe434a5caf85"
}
