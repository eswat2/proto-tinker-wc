{
  "name": "proto-tinker-wc",
  "version": "0.1.213",
  "description": "prototype - simple demo built from Stencil & Tailwind",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "es2015": "dist/esm/index.mjs",
  "es2017": "dist/esm/index.mjs",
  "types": "dist/types/components.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/proto-tinker-wc/proto-tinker-wc.js",
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "bump": "bumpp patch --commit --tag --push --yes",
    "release": "pnpm bump && pnpm build",
    "preinstall": "npx only-allow pnpm",
    "dev": "concurrently \"pnpm:twx --watch\" \"pnpm:start\"",
    "twx": "twx",
    "build": "pnpm twx; pnpm format; stencil build --docs",
    "start": "stencil build --dev --watch --serve",
    "test": "echo --skip",
    "generate": "stencil generate",
    "spell": "cspell 'src/**/*.{ts,tsx,html,css,md}' ",
    "cc": "prettier --check src",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@stencil/core": "4.43.5",
    "@stencil/store": "2.2.2"
  },
  "devDependencies": {
    "autoprefixer": "10.5.0",
    "bumpp": "11.1.0",
    "concurrently": "10.0.3",
    "cspell": "10.0.1",
    "eslint": "10.5.0",
    "only-allow": "1.2.2",
    "postcss": "8.5.15",
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "proto-tailwindcss-clrs": "0.0.507",
    "tailwindcss": "4.3.1",
    "typescript": "5.9.3",
    "workbox-build": "7.4.1",
    "yoctocolors": "2.1.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/eswat2/proto-tinker-wc.git"
  },
  "license": "MIT",
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
}
